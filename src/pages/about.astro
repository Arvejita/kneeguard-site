---
import Layout from '../layouts/Layout.astro';

const equipo = [
  {
    nombre: "Martin",
    rol: "Director de Animación / Lead In-betweener",
    bio: "Especialista en fluidez analógica y sistemas de producción indie.",
    foto: "/images/team/martin.jpg" 
  },
  {
    nombre: "Remato", 
    rol: "Key-framer Digital",
    bio: "Encargado de la estructura y el timing digital de las piezas.",
    foto: "/images/team/remato.jpg"
  },
  {
    nombre: "Eker da goat",
    rol: "Main-animator",
    bio: "Encargado de la estructura y el timing digital de las piezas.",
    foto: "/images/team/eker.jpg" 
  }
];
---

<Layout title="Sobre Nosotros | Knee Guard Studios">
  <nav style="margin-bottom: 3rem;">
    <a href="/" class="nav-back">← INICIO</a>
  </nav>

  <section>
    <h1 style="font-size: 2.5rem; margin-bottom: 1rem; font-family: 'TX-02', monospace; font-weight: 900;">Knee Guard Studios</h1>
    <p style="font-size: 1.1rem; max-width: 60ch; margin-bottom: 4rem; font-family: 'TX-02', monospace; font-weight: 300;">
      Somos un colectivo de animación enfocado en la textura del movimiento. 
      Creemos en el proceso híbrido: la calidez del trazo manual combinada con la precisión digital.
    </p>

    <h2 style="text-transform: uppercase; font-size: 0.8rem; letter-spacing: 2px; color: var(--muted); margin-bottom: 2rem; font-family: 'TX-02', monospace;">El Equipo</h2>
    
    <div style="display: grid; gap: 3rem;">
      {equipo.map(miembro => (
        <div class="team-member-row" style="display: flex; flex-direction: row; align-items: center; gap: 2rem;">
          
          <div 
            class="member-avatar" 
            style={miembro.foto ? `background-image: url(${miembro.foto});` : ''}
          >
          </div> 

          <div class="member-info">
            <h3 style="margin: 0; font-size: 1.2rem; font-family: 'TX-02', monospace; font-weight: 700;">{miembro.nombre}</h3>
            <p style="margin: 0; color: var(--accent); font-family: 'TX-02', monospace; font-size: 0.8rem; font-weight: 500;">{miembro.rol}</p>
            <p style="margin-top: 0.5rem; color: var(--muted); font-size: 0.9rem; max-width: 40ch; font-family: 'TX-02', monospace; font-weight: 300; line-height: 1.4;">
              {miembro.bio}
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>

<style is:global>
  .nav-back {
    text-decoration: none;
    color: var(--fg);
    font-family: 'TX-02', monospace;
    font-size: 0.85rem;
    font-weight: 500;
    padding-bottom: 2px;
    border-bottom: 1px solid var(--accent); 
    transition: opacity 0.2s ease;
  }

  .nav-back:hover { opacity: 0.7; }

  .member-avatar {
    width: 70px;
    height: 70px;
    background-color: var(--fg); /* Color de fondo si no hay foto */
    border-radius: 50%;
    flex-shrink: 0;
    
    /* CORRECCIÓN: Usamos contain para ver la foto cuadrada completa */
    background-size: contain; 
    background-position: center;
    background-repeat: no-repeat;
    
    /* El efecto de grayscale se mantiene */
    filter: grayscale(1);
    transition: filter 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .team-member-row:hover .member-avatar {
    filter: grayscale(0);
  }

  .member-info {
    display: flex;
    flex-direction: column;
  }
</style>